{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "additionalProperties": false,
  "comment": "OCPP 2.0.1 FINAL",
  "definitions": {
    "CertificateHashDataChainType": {
      "additionalProperties": false,
      "javaType": "CertificateHashDataChain",
      "properties": {
        "certificateHashData": {
          "$ref": "#/definitions/CertificateHashDataType"
        },
        "certificateType": {
          "$ref": "#/definitions/GetCertificateIdUseEnumType"
        },
        "childCertificateHashData": {
          "additionalItems": false,
          "items": {
            "$ref": "#/definitions/CertificateHashDataType"
          },
          "maxItems": 4,
          "minItems": 1,
          "type": "array"
        },
        "customData": {
          "$ref": "#/definitions/CustomDataType"
        }
      },
      "required": [
        "certificateType",
        "certificateHashData"
      ],
      "type": "object"
    },
    "CertificateHashDataType": {
      "additionalProperties": false,
      "javaType": "CertificateHashData",
      "properties": {
        "customData": {
          "$ref": "#/definitions/CustomDataType"
        },
        "hashAlgorithm": {
          "$ref": "#/definitions/HashAlgorithmEnumType"
        },
        "issuerKeyHash": {
          "description": "Hashed value of the issuers public key\r\n",
          "maxLength": 128,
          "type": "string"
        },
        "issuerNameHash": {
          "description": "Hashed value of the Issuer DN (Distinguished Name).\r\n\r\n",
          "maxLength": 128,
          "type": "string"
        },
        "serialNumber": {
          "description": "The serial number of the certificate.\r\n",
          "maxLength": 40,
          "type": "string"
        }
      },
      "required": [
        "hashAlgorithm",
        "issuerNameHash",
        "issuerKeyHash",
        "serialNumber"
      ],
      "type": "object"
    },
    "CustomDataType": {
      "description": "This class does not get 'AdditionalProperties = false' in the schema generation, so it can be extended with arbitrary JSON properties to allow adding custom data.",
      "javaType": "CustomData",
      "properties": {
        "vendorId": {
          "maxLength": 255,
          "type": "string"
        }
      },
      "required": [
        "vendorId"
      ],
      "type": "object"
    },
    "GetCertificateIdUseEnumType": {
      "additionalProperties": false,
      "description": "Indicates the type of the requested certificate(s).\r\n",
      "enum": [
        "V2GRootCertificate",
        "MORootCertificate",
        "CSMSRootCertificate",
        "V2GCertificateChain",
        "ManufacturerRootCertificate"
      ],
      "javaType": "GetCertificateIdUseEnum",
      "type": "string"
    },
    "GetInstalledCertificateStatusEnumType": {
      "additionalProperties": false,
      "description": "Charging Station indicates if it can process the request.\r\n",
      "enum": [
        "Accepted",
        "NotFound"
      ],
      "javaType": "GetInstalledCertificateStatusEnum",
      "type": "string"
    },
    "HashAlgorithmEnumType": {
      "additionalProperties": false,
      "description": "Used algorithms for the hashes provided.\r\n",
      "enum": [
        "SHA256",
        "SHA384",
        "SHA512"
      ],
      "javaType": "HashAlgorithmEnum",
      "type": "string"
    },
    "StatusInfoType": {
      "additionalProperties": false,
      "description": "Element providing more information about the status.\r\n",
      "javaType": "StatusInfo",
      "properties": {
        "additionalInfo": {
          "description": "Additional text to provide detailed information.\r\n",
          "maxLength": 512,
          "type": "string"
        },
        "customData": {
          "$ref": "#/definitions/CustomDataType"
        },
        "reasonCode": {
          "description": "A predefined code for the reason why the status is returned in this response. The string is case-insensitive.\r\n",
          "maxLength": 20,
          "type": "string"
        }
      },
      "required": [
        "reasonCode"
      ],
      "type": "object"
    }
  },
  "properties": {
    "certificateHashDataChain": {
      "additionalItems": false,
      "items": {
        "$ref": "#/definitions/CertificateHashDataChainType"
      },
      "minItems": 1,
      "type": "array"
    },
    "customData": {
      "$ref": "#/definitions/CustomDataType"
    },
    "status": {
      "$ref": "#/definitions/GetInstalledCertificateStatusEnumType"
    },
    "statusInfo": {
      "$ref": "#/definitions/StatusInfoType"
    }
  },
  "required": [
    "status"
  ],
  "type": "object"
}
